{
  "manifestVersion": 5,
  "id": "com.textcue.ai.premiere",
  "name": "TextCue AI",
  "version": "0.1.6",
  "main": "index.html",
  "host": {
    "app": "premierepro",
    "minVersion": "25.6.0"
  },
  "entrypoints": [
    {
      "type": "panel",
      "id": "textCuePanel",
      "label": {
        "default": "TextCue AI"
      },
      "minimumSize": {
        "width": 420,
        "height": 520
      },
      "preferredDockedSize": {
        "width": 560,
        "height": 720
      },
      "preferredFloatingSize": {
        "width": 860,
        "height": 760
      }
    }
  ],
  "requiredPermissions": {
    "localFileSystem": "request",
    "network": {
      "domains": [
        "https://api.github.com",
        "https://github.com"
      ]
    }
  },
  "featureFlags": {
    "enableAlerts": true
  }
}
